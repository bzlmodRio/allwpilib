diff --git a/pycross/private/tools/wheel_installer.py b/pycross/private/tools/wheel_installer.py
index 5555555..6666666 100644
--- a/pycross/private/tools/wheel_installer.py
+++ b/pycross/private/tools/wheel_installer.py
@@ -110,7 +110,16 @@
         wheel_name = os.path.basename(args.wheel)
 
     link_path = link_dir / wheel_name
-    os.symlink(os.path.join(os.getcwd(), args.wheel), link_path)
+    # os.symlink requires SeCreateSymbolicLinkPrivilege on Windows (elevation
+    # or Developer Mode), which isn't available in a typical non-elevated
+    # Bazel build. A hardlink (falling back to a copy across volumes) needs
+    # no special privilege and is just as good here, since link_path is only
+    # ever opened for reading.
+    wheel_abspath = os.path.join(os.getcwd(), args.wheel)
+    try:
+        os.link(wheel_abspath, link_path)
+    except OSError:
+        shutil.copyfile(wheel_abspath, link_path)
 
     try:
         with FilteredWheelFile.open_filtered(link_path, args.install_exclude_globs) as source:

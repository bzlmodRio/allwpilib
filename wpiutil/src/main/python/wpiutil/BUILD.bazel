load("//shared/bazel/rules/python/pybind_generator:generate_robotpy_project_files.bzl", "generate_robotpy_project_files")
load("//shared/bazel/rules/python/pybind_generator:pybind_rules.bzl", "create_pybind_library")
load("@aspect_bazel_lib//lib:copy_file.bzl", "copy_file")

generate_robotpy_project_files(
    name = "wpiutil",
    config_file = "//wpiutil/src/main/python:config_file",
    visibility = ["//wpiutil/src/main/python:__subpackages__"],
)

create_pybind_library(
    "wpiutil",
    entry_point = ["src/main.cpp"],
    extension_visibility = ["//wpiutil/src/main/python:__subpackages__"],
    extra_hdrs = glob(["src/type_casters/*.h"]),
    extra_srcs = glob(
        ["src/**/*.cpp"],
        exclude = ["src/main.cpp"],
    ),
    generation_helper_prefix = "//wpiutil/src/main/python:wpiutil",
    strip_include_prefix = "src/type_casters",
    deps = [
        "//wpiutil/src/main/native:wpiutil.shared",
    ],
)

copy_file(
    name = "copy_lib",
    src = "//wpiutil/src/main/native:wpiutil",
    out = "lib/wpiutil.dll",
    visibility = ["//visibility:public"]
)

filegroup(
    name = "python_files",
    srcs = glob(["**/*.py"]),
    visibility = ["//wpiutil/src/main/python:__subpackages__"],
)

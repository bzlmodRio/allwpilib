load("//shared/bazel/rules/python/pybind_generator:pybind_rules.bzl", "create_pybind_library")

create_pybind_library(
    name = "wpimath_test",
    entry_point = ["src/module.cpp"],
    extension_visibility = ["//wpimath/src/test/python:__subpackages__"],
    extra_hdrs = glob(["include/*.h"]),
    generation_helper_prefix = "//wpimath/src/test/python/cpp:wpimath_test",
    strip_include_prefix = "include",
    deps = [
        "//wpimath/src/main/python/wpimath:wpimath_pybind_library",
        "//wpiutil/src/main/python/wpiutil:wpiutil_pybind_library",
    ],
)

filegroup(
    name = "python_files",
    srcs = glob(["**/*.py"]),
    visibility = ["//wpimath/src/test/python:__subpackages__"],
)

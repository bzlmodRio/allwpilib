load("//shared/bazel/rules:java_rules.bzl", "wpilib_java_junit5_test", "wpilib_java_library")

REMAINDER_TEST_SRCS = []

wpilib_java_library(
    name = "utility_class_test",
    srcs = ["wpilibj/UtilityClassTest.java"],
    deps = ["@maven//:org_junit_jupiter_junit_jupiter_api"],
)

REMAINDER_TEST_SRCS.append("wpilibj/UtilityClassTest.java")

REMAINDER_TEST_FILES = glob(
    [
        "**/*.java",
    ],
    exclude = REMAINDER_TEST_SRCS + ["math/jni/**"],
)

print(REMAINDER_TEST_FILES)

wpilib_java_junit5_test(
    name = "wpimath-test",
    size = "small",
    srcs = REMAINDER_TEST_FILES,
    deps = [
        ":utility_class_test",
        "//wpimath/src/main/java/edu/wpi/first/math:wpimath-core",
        "//wpimath/src/main/java/edu/wpi/first/math:wpimath-dare",
        "//wpimath/src/main/java/edu/wpi/first/math:wpimath-geometry",
        "//wpimath/src/main/java/edu/wpi/first/math:wpimath-remainder",
        "//wpiutil/src/main/java/edu/wpi/first/util:wpiutil",
        "@maven//:org_ejml_ejml_core",
        "@maven//:org_ejml_ejml_simple",
    ],
)

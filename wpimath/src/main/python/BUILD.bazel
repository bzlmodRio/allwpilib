    rpy_include_dir = "generated/rpy-include/wpimath/spline/rpy-include",
    visibility = ["//wpimath/src/main/python:__subpackages__"],
)

generate_robopy_files(
    name = "wpimath",
    config_file = ":pyproject.toml",
    headers = ["//wpimath/src/main/native:headers"],
    projects = [
        "wpimath",
        "_impl",
        "_controls",

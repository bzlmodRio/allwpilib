From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Peter Johnson <johnson.peter@gmail.com>
Date: Sat, 10 Jun 2023 15:00:20 -0700
Subject: [PATCH 3/9] Fix maybe-uninitialized warnings

---
 src/google/protobuf/arena.cc                         |  4 ++--
 .../protobuf/generated_message_tctable_lite.cc       | 12 ++++++------
 src/google/protobuf/io/coded_stream.cc               |  2 +-
 3 files changed, 9 insertions(+), 9 deletions(-)

diff --git a/src/google/protobuf/arena.cc b/src/google/protobuf/arena.cc
index 6577a3669217ac867a4a7ea64e5273b266124ce0..00f8a1e69bc6427b65642c517e966fd311cb3c61 100644
--- a/src/google/protobuf/arena.cc
+++ b/src/google/protobuf/arena.cc
@@ -769,7 +769,7 @@ uint64_t ThreadSafeArena::Reset() {
 
 void* ThreadSafeArena::AllocateAlignedWithCleanup(size_t n, size_t align,
                                                   void (*destructor)(void*)) {
-  SerialArena* arena;
+  SerialArena* arena = nullptr;
   if (PROTOBUF_PREDICT_TRUE(GetSerialArenaFast(&arena))) {
     return arena->AllocateAlignedWithCleanup(n, align, destructor);
   } else {
@@ -782,7 +782,7 @@ void ThreadSafeArena::AddCleanup(void* elem, void (*cleanup)(void*)) {
 }
 
 SerialArena* ThreadSafeArena::GetSerialArena() {
-  SerialArena* arena;
+  SerialArena* arena = nullptr;
   if (PROTOBUF_PREDICT_FALSE(!GetSerialArenaFast(&arena))) {
     arena = GetSerialArenaFallback(kMaxCleanupNodeSize);
   }
diff --git a/src/google/protobuf/generated_message_tctable_lite.cc b/src/google/protobuf/generated_message_tctable_lite.cc
index f2b36ee491d5ba35626540e2cc38c21dd3d89ee4..61836a0cd746a2168e8201123dcd8ffb15ec18ab 100644
--- a/src/google/protobuf/generated_message_tctable_lite.cc
+++ b/src/google/protobuf/generated_message_tctable_lite.cc
@@ -1136,7 +1136,7 @@ PROTOBUF_ALWAYS_INLINE const char* TcParser::SingularEnum(
   }
   const char* ptr2 = ptr;  // Save for unknown enum case
   ptr += sizeof(TagType);  // Consume tag
-  uint64_t tmp;
+  uint64_t tmp = 0;
   ptr = ParseVarint(ptr, &tmp);
   if (ptr == nullptr) {
     PROTOBUF_MUSTTAIL return Error(PROTOBUF_TC_PARAM_NO_DATA_PASS);
@@ -1186,7 +1186,7 @@ const char* TcParser::RepeatedEnum(PROTOBUF_TC_PARAM_DECL) {
   do {
     const char* ptr2 = ptr;  // save for unknown enum case
     ptr += sizeof(TagType);
-    uint64_t tmp;
+    uint64_t tmp = 0;
     ptr = ParseVarint(ptr, &tmp);
     if (ptr == nullptr) {
       PROTOBUF_MUSTTAIL return Error(PROTOBUF_TC_PARAM_NO_DATA_PASS);
@@ -1898,7 +1898,7 @@ PROTOBUF_NOINLINE const char* TcParser::MpVarint(PROTOBUF_TC_PARAM_DECL) {
 
   // Parse the value:
   const char* ptr2 = ptr;  // save for unknown enum case
-  uint64_t tmp;
+  uint64_t tmp = 0;
   ptr = ParseVarint(ptr, &tmp);
   if (ptr == nullptr) {
     PROTOBUF_MUSTTAIL return Error(PROTOBUF_TC_PARAM_NO_DATA_PASS);
@@ -1967,7 +1967,7 @@ PROTOBUF_NOINLINE const char* TcParser::MpRepeatedVarint(
     const char* ptr2 = ptr;
     uint32_t next_tag;
     do {
-      uint64_t tmp;
+      uint64_t tmp = 0;
       ptr = ParseVarint(ptr2, &tmp);
       if (ptr == nullptr) {
         PROTOBUF_MUSTTAIL return Error(PROTOBUF_TC_PARAM_NO_DATA_PASS);
@@ -1984,7 +1984,7 @@ PROTOBUF_NOINLINE const char* TcParser::MpRepeatedVarint(
     const char* ptr2 = ptr;
     uint32_t next_tag;
     do {
-      uint64_t tmp;
+      uint64_t tmp = 0;
       ptr = ParseVarint(ptr2, &tmp);
       if (ptr == nullptr) {
         PROTOBUF_MUSTTAIL return Error(PROTOBUF_TC_PARAM_NO_DATA_PASS);
@@ -2011,7 +2011,7 @@ PROTOBUF_NOINLINE const char* TcParser::MpRepeatedVarint(
     const char* ptr2 = ptr;
     uint32_t next_tag;
     do {
-      uint64_t tmp;
+      uint64_t tmp = 0;
       ptr = ParseVarint(ptr2, &tmp);
       if (ptr == nullptr) {
         PROTOBUF_MUSTTAIL return Error(PROTOBUF_TC_PARAM_NO_DATA_PASS);
diff --git a/src/google/protobuf/io/coded_stream.cc b/src/google/protobuf/io/coded_stream.cc
index b2bb0cc6805343bcb64f62ad526a83cca6afad2f..d05c2afc0898e5933e66850c7b34c31d01403683 100644
--- a/src/google/protobuf/io/coded_stream.cc
+++ b/src/google/protobuf/io/coded_stream.cc
@@ -517,7 +517,7 @@ int64_t CodedInputStream::ReadVarint32Fallback(uint32_t first_byte_or_zero) {
       (buffer_end_ > buffer_ && !(buffer_end_[-1] & 0x80))) {
     ABSL_DCHECK_NE(first_byte_or_zero, 0)
         << "Caller should provide us with *buffer_ when buffer is non-empty";
-    uint32_t temp;
+    uint32_t temp = 0;
     ::std::pair<bool, const uint8_t*> p =
         ReadVarint32FromArray(first_byte_or_zero, buffer_, &temp);
     if (!p.first) return -1;

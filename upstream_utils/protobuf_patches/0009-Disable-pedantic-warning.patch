From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Peter Johnson <johnson.peter@gmail.com>
Date: Wed, 14 Jun 2023 00:02:26 -0700
Subject: [PATCH 09/10] Disable pedantic warning

---
 src/google/protobuf/descriptor.h                    | 8 ++++++++
 src/google/protobuf/generated_message_reflection.cc | 2 ++
 src/google/protobuf/parse_context.h                 | 8 ++++++++
 3 files changed, 18 insertions(+)

diff --git a/src/google/protobuf/descriptor.h b/src/google/protobuf/descriptor.h
index 3c903a1fec361c681e65b1d689f36573165bacb4..31fc10fba8f268ff662cae11522d579ab45b8994 100644
--- a/src/google/protobuf/descriptor.h
+++ b/src/google/protobuf/descriptor.h
@@ -65,6 +65,10 @@
 #define PROTOBUF_IGNORE_DEPRECATION_STOP
 #endif
 
+#ifdef __GNUC__
+#pragma GCC diagnostic push
+#pragma GCC diagnostic ignored "-Wpedantic"
+#endif
 
 namespace google {
 namespace protobuf {
@@ -2886,6 +2890,10 @@ PROTOBUF_EXPORT bool IsLazilyInitializedFile(absl::string_view filename);
 }  // namespace protobuf
 }  // namespace google
 
+#ifdef __GNUC__
+#pragma GCC diagnostic pop
+#endif
+
 #undef PROTOBUF_INTERNAL_CHECK_CLASS_SIZE
 #include "google/protobuf/port_undef.inc"
 
diff --git a/src/google/protobuf/generated_message_reflection.cc b/src/google/protobuf/generated_message_reflection.cc
index c2ace6401d681c417006a81a6a41ecd13909c78d..8c259c6d488e816fd7dc3513164e424ddd7598a1 100644
--- a/src/google/protobuf/generated_message_reflection.cc
+++ b/src/google/protobuf/generated_message_reflection.cc
@@ -71,6 +71,8 @@ using google::protobuf::internal::cpp::IsLazilyInitializedFile;
 
 #ifdef _MSC_VER
 #pragma warning(disable : 4065)
+#elif defined(__GNUC__)
+#pragma GCC diagnostic ignored "-Wpedantic"
 #endif
 
 namespace google {
diff --git a/src/google/protobuf/parse_context.h b/src/google/protobuf/parse_context.h
index 9292d517feebfef28d6dabb48e39e31733874e37..e86e203f2815b2ba18318e9a4d38cd447f7f380d 100644
--- a/src/google/protobuf/parse_context.h
+++ b/src/google/protobuf/parse_context.h
@@ -37,6 +37,10 @@
 // Must be included last.
 #include "google/protobuf/port_def.inc"
 
+#ifdef __GNUC__
+#pragma GCC diagnostic push
+#pragma GCC diagnostic ignored "-Wpedantic"
+#endif
 
 namespace google {
 namespace protobuf {
@@ -1394,6 +1398,10 @@ PROTOBUF_NODISCARD PROTOBUF_EXPORT const char* UnknownFieldParse(
 }  // namespace protobuf
 }  // namespace google
 
+#ifdef __GNUC__
+#pragma GCC diagnostic pop
+#endif
+
 #include "google/protobuf/port_undef.inc"
 
 #endif  // GOOGLE_PROTOBUF_PARSE_CONTEXT_H__

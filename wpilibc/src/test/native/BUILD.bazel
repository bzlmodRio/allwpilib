load("//shared/bazel/rules:cc_rules.bzl", "wpilib_cc_library", "wpilib_cc_test")

wpilib_cc_library(
    name = "test-headers",
    testonly = True,
    hdrs = glob(["include/**"]),
    includes = ["include"],
)

wpilib_cc_test(
    name = "wpilibc-test",
    size = "small",
    srcs = glob(["cpp/**"]),
    linkstatic = 1,
    tags = [
        "no-asan",
        "no-tsan",
    ],
    deps = [
        ":test-headers",
        "//cameraserver/src/main/native:cameraserver.static",
        "//wpilibc/src/main/native:wpilibc.static",
        "@gtest",
    ],
)
